#!/bin/zsh
# fall-serve — manage the zoekt webserver daemon
# Usage: fall-serve {start|stop|status|restart}

set -euo pipefail

INDEX_DIR="${ZOEKT_INDEX_DIR:-$HOME/.zoekt}"
PID_FILE="$INDEX_DIR/webserver.pid"
LISTEN="${FALL_SERVE_LISTEN:-:6070}"

# Find zoekt-webserver
if command -v zoekt-webserver &>/dev/null; then
    SERVER=zoekt-webserver
elif [[ -x "$HOME/go/bin/zoekt-webserver" ]]; then
    SERVER="$HOME/go/bin/zoekt-webserver"
else
    echo "error: zoekt-webserver not found. Run: go install github.com/sourcegraph/zoekt/cmd/zoekt-webserver@latest" >&2
    exit 1
fi

is_running() {
    [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

do_start() {
    if is_running; then
        echo "already running (pid $(cat "$PID_FILE"))"
        return 0
    fi
    mkdir -p "$INDEX_DIR"
    "$SERVER" -listen "$LISTEN" -index "$INDEX_DIR" -rpc &>/dev/null &
    echo $! > "$PID_FILE"
    echo "started on $LISTEN (pid $!)"
}

do_stop() {
    if is_running; then
        local pid=$(cat "$PID_FILE")
        kill "$pid"
        rm -f "$PID_FILE"
        echo "stopped (pid $pid)"
    else
        rm -f "$PID_FILE"
        echo "not running"
    fi
}

do_status() {
    if is_running; then
        echo "running (pid $(cat "$PID_FILE")) on $LISTEN"
        echo "index: $INDEX_DIR"
        local shards=$(ls "$INDEX_DIR"/*.zoekt 2>/dev/null | wc -l | tr -d ' ')
        echo "shards: $shards"
    else
        echo "not running"
    fi
}

case "${1:-}" in
    start)   do_start ;;
    stop)    do_stop ;;
    status)  do_status ;;
    restart) do_stop; sleep 1; do_start ;;
    *)       echo "Usage: fall-serve {start|stop|status|restart}" >&2; exit 1 ;;
esac
